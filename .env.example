# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Opcional: bypassa RLS em Server Actions (criar org etc). Use a "service_role" (secret) do Supabase.
SUPABASE_SERVICE_ROLE_KEY=

# Cron: em produção (ex. Vercel) defina e envie no header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# API do agente de IA (`/api/agent/v1/*`): valida tokens em `api_tokens` com o cliente admin.
# Sem esta chave, as rotas do agente respondem 503.
# O segredo enviado pelo cliente deve ser o valor salvo em api_tokens.token_hash (igual ao embed/KPI).
